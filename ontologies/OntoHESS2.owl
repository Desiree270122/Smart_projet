  </rdfs:domain>
  <rdfs:domain>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#powers"/>
      <owl:someValuesFrom rdf:resource="#Load"/>
    </owl:Restriction>
  </rdfs:domain>
  <rdfs:range rdf:resource="#Component"/>
  <rdfs:range rdf:resource="#Converter"/>
  <rdfs:range>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#manages"/>
      <owl:someValuesFrom rdf:resource="#Batteries"/>
    </owl:Restriction>
  </rdfs:range>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links the HESS to its DC-DC converter.</rdfs:comment>
</owl:ObjectProperty>

