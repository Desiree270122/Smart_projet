          <owl:inverseOf rdf:resource="#hasSOCState"/>
        </rdf:Description>
      </owl:onProperty>
      <owl:someValuesFrom rdf:resource="#Batteries"/>
    </owl:Restriction>
  </rdfs:range>
</owl:ObjectProperty>

