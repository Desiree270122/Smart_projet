    </owl:Restriction>
  </rdfs:range>
  <rdfs:range>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasThreshold"/>
      <owl:someValuesFrom rdf:resource="#PowerThreshold"/>
    </owl:Restriction>
  </rdfs:range>
  <rdfs:range>
    <owl:Restriction>
