<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.semanticweb.org/ontologies/OntoHESS"
         xmlns="http://www.semanticweb.org/ontologies/OntoHESS#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://www.semanticweb.org/ontologies/OntoHESS"/>

<owl:ObjectProperty rdf:about="#appliesCalculation">
  <rdfs:domain rdf:resource="#ManagementStrategy"/>
  <rdfs:domain>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#controls"/>
      <owl:someValuesFrom rdf:resource="#Converter"/>
    </owl:Restriction>
  </rdfs:domain>
  <rdfs:domain>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#drives"/>
      <owl:someValuesFrom rdf:resource="#HESS"/>
    </owl:Restriction>
  </rdfs:domain>
  <rdfs:range rdf:resource="#ManagementStrategy"/>
  <rdfs:range rdf:resource="#PconvCalculation"/>
  <rdfs:range>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#appliesCalculation"/>
      <owl:someValuesFrom rdf:resource="#ManagementStrategy"/>
    </owl:Restriction>
  </rdfs:range>
  <rdfs:range>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#controls"/>
      <owl:someValuesFrom rdf:resource="#Converter"/>
    </owl:Restriction>
  </rdfs:range>
  <rdfs:range>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#drives"/>
      <owl:someValuesFrom rdf:resource="#HESS"/>
    </owl:Restriction>
  </rdfs:range>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#controls">
